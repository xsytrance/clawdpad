#!/usr/bin/env python3
"""blockctl — talk to Clawd on the Lightpad (clawdpadd's CLI).

Thin client for clawdpadd's Unix socket. Exits 0 silently when the daemon
is not running, so Claude Code hooks and timers never fail. The command
vocabulary is compatible with dazzler's claudectl, so a fan-out script can
drive both bodies with one call.

Commands:
  event-hook <start|prompt|stop|end>   consume Claude Code hook JSON on stdin
  event-hook <pre-tool|post-tool>      tool activity — feeds Clawd's work
                                       energy (he paces faster)
  mode <awake|thinking|sleep|notify>   set mood manually
  say "text" [-t SECONDS]              notify (wave + chime); tap to ack
  anim <celebrate>                     jump with both arms up
  play [jingle|hello|chime]            play a melody (jingle also jumps)
  hum <on|off>                         ambient pad while thinking
  visit                                send Clawd to the other block (2+)
  game <pong|off>                      pong! two blocks = versus, one = wall
  names                                each glass scrolls its own name tag
  size <full|mini>                     big Clawd, or chibi-Clawd roaming
  qr [text] [-t SECONDS]               the glass becomes a Micro QR (M3=15x15)
  costume [id]                         dress him (see 'costume list')
  marquee [text]                       scroll a message (empty clears it)
  demo                                 tour every mood (for showing friends)
  status                               mood · block · energy · sessions
  sessions                             print the session registry
  clear                                clear notify + manual mode
  where                                print daemon socket path (if alive)
"""

import json
import os
import re
import socket
import sys

TEST_RE = re.compile(r"\b(pytest|unittest|npm (run )?test|yarn test|pnpm test"
                     r"|cargo test|go test|make (test|check)|jest|vitest|tox"
                     r"|ctest|rspec|phpunit)\b")
FAIL_RE = re.compile(r"exit code:?\s*[1-9]|\bcommand failed\b")


def socket_path():
    for base in (os.environ.get("XDG_RUNTIME_DIR"), "/tmp"):
        if base:
            p = os.path.join(base, "clawdpad", "clawdpad.sock")
            if os.path.exists(p):
                return p
    return None


def send(msg):
    """Returns the daemon's reply dict, or None when the daemon is absent."""
    path = socket_path()
    if path is None:
        return None
    try:
        with socket.socket(socket.AF_UNIX, socket.SOCK_STREAM) as sock:
            sock.settimeout(3.0)
            sock.connect(path)
            sock.sendall(json.dumps(msg).encode() + b"\n")
            buf = b""
            while b"\n" not in buf:
                chunk = sock.recv(4096)
                if not chunk:
                    return None
                buf += chunk
            return json.loads(buf.split(b"\n")[0])
    except (OSError, ValueError):
        return None


def tool_event(kind, sid, payload):
    """Map a Pre/PostToolUse hook payload to a work-energy bump.

    No visuals of their own — the energy meter sets how fast Clawd paces
    while thinking. Failing commands and passing test runs bump harder.
    """
    tool = str(payload.get("tool_name") or "").lower()
    if kind == "pre-tool":
        send({"cmd": "event", "kind": "ripple", "sid": sid})
        return
    if tool != "bash":
        return
    resp = payload.get("tool_response")
    if isinstance(resp, dict):
        text = " ".join(str(v) for v in resp.values() if isinstance(v, str))
        interrupted = bool(resp.get("interrupted"))
    else:
        text, interrupted = str(resp or ""), False
    if interrupted or FAIL_RE.search(text[-2000:].lower()):
        send({"cmd": "event", "kind": "flash", "sid": sid})
        return
    command = str((payload.get("tool_input") or {}).get("command") or "")
    if TEST_RE.search(command):
        send({"cmd": "event", "kind": "wave", "sid": sid})


def main(argv):
    if not argv:
        print(__doc__)
        return 0
    cmd, args = argv[0], argv[1:]

    if cmd == "where":
        reply = send({"cmd": "ping"})
        if reply:
            print(socket_path())
        return 0

    if cmd == "event-hook":
        kind = args[0] if args else "prompt"
        if kind not in ("start", "prompt", "stop", "end",
                        "pre-tool", "post-tool"):
            print(f"unknown hook kind: {kind}", file=sys.stderr)
            return 1
        try:
            payload = json.load(sys.stdin)
        except (ValueError, OSError):
            payload = {}
        sid = (payload.get("session_id") or "manual")[:8]
        if kind in ("pre-tool", "post-tool"):
            tool_event(kind, sid, payload)
            return 0
        cwd = payload.get("cwd") or ""
        project = os.path.basename(cwd.rstrip("/")) if cwd else "somewhere"
        send({"cmd": "event-hook", "kind": kind, "sid": sid, "project": project})
        return 0

    if cmd == "mode":
        arg = (args[0] if args else "awake").lower()
        if arg not in ("awake", "thinking", "sleep", "notify"):
            print(f"unknown mode: {arg}", file=sys.stderr)
            return 1
        send({"cmd": "mode", "arg": arg})
    elif cmd == "say":
        seconds = 30.0
        if "-t" in args:
            i = args.index("-t")
            seconds = float(args[i + 1])
            args = args[:i] + args[i + 2:]
        send({"cmd": "say", "arg": " ".join(args), "seconds": seconds})
    elif cmd == "anim":
        send({"cmd": "anim", "arg": (args[0] if args else "celebrate").lower()})
    elif cmd == "play":
        reply = send({"cmd": "play",
                      "arg": (args[0] if args else "jingle").lower()})
        if reply and not reply.get("ok"):
            print(reply.get("error"), file=sys.stderr)
    elif cmd == "hum":
        send({"cmd": "hum", "arg": (args[0] if args else "on").lower()})
    elif cmd == "visit":
        reply = send({"cmd": "visit"})
        if reply and not reply.get("ok"):
            print(reply.get("error"), file=sys.stderr)
    elif cmd == "game":
        reply = send({"cmd": "game",
                      "arg": (args[0] if args else "pong").lower()})
        if reply and not reply.get("ok"):
            print(reply.get("error"), file=sys.stderr)
    elif cmd == "names":
        reply = send({"cmd": "names"})
        if reply and not reply.get("ok"):
            print(reply.get("error"), file=sys.stderr)
        elif reply:
            for serial, name in reply.get("names", {}).items():
                print(f"{name:<10} {serial}")
    elif cmd == "size":
        send({"cmd": "size", "arg": (args[0] if args else "full").lower()})
    elif cmd == "costume":
        arg = (args[0] if args else "none").lower()
        if arg == "list":
            reply = send({"cmd": "status"})
            print("costumes: none tophat shades party crown phones scarf bow "
                  "halo horns wizard cowboy flower | ghost puff chomper robot "
                  "cat frog alien pumpkin star bee")
            return 0
        reply = send({"cmd": "costume", "arg": arg})
        if reply and not reply.get("ok"):
            print(reply.get("error"), file=sys.stderr)
    elif cmd == "marquee":
        send({"cmd": "marquee", "arg": " ".join(args)})
    elif cmd == "qr":
        seconds = 30.0
        if "-t" in args:
            i = args.index("-t")
            seconds = float(args[i + 1])
            args = args[:i] + args[i + 2:]
        reply = send({"cmd": "qr", "arg": args[0] if args else "CLAWDPAD",
                      "seconds": seconds})
        if reply and not reply.get("ok"):
            print(reply.get("error"), file=sys.stderr)
    elif cmd == "demo":
        import time
        steps = [
            ("awake — he breathes, blinks, glances around",
             [{"cmd": "mode", "arg": "awake"}], 6),
            ("thinking — pacing, eyes leading (energy = speed)",
             [{"cmd": "mode", "arg": "thinking"},
              {"cmd": "event", "kind": "flash"},
              {"cmd": "event", "kind": "flash"}], 6),
            ("notify — waving for your attention (tap him to ack)",
             [{"cmd": "say", "arg": "demo", "seconds": 5}], 5),
            ("celebrate — arms up, jumping (+ jingle)",
             [{"cmd": "play", "arg": "jingle"}], 3.5),
            ("sleep — dim, eyes closed, occasional peek",
             [{"cmd": "mode", "arg": "sleep"}], 5),
        ]
        for line, msgs, wait in steps:
            print(line)
            for m in msgs:
                send(m)
            time.sleep(wait)
        send({"cmd": "clear"})
        print("demo over — Clawd goes back to his life")
    elif cmd == "clear":
        send({"cmd": "clear"})
    elif cmd in ("status", "sessions"):
        reply = send({"cmd": "status"})
        if reply is None:
            print("clawdpadd not running")
            return 0
        if cmd == "status":
            blk = reply.get("block", {})
            n = blk.get("blocks", 1)
            home = reply.get("home", "")
            where = (f"{blk.get('serial')}"
                     + (f" +{n - 1} more (home {home})" if n > 1 else "")
                     + f" battery {blk.get('battery')}%"
                     if blk.get("connected") else "block absent")
            print(f"mood {reply.get('mood')}  ·  {where}  ·  "
                  f"energy {reply.get('energy', 0):.2f}  ·  "
                  f"{len(reply.get('sessions', {}))} session(s)  ·  "
                  f"daemon up {reply.get('uptime')}s")
            if pet := reply.get("pet"):
                print(f"soul: level {pet['level']}  ·  {pet['mood']} "
                      f"(hunger {pet['hunger']:.0f})  ·  xp {pet['xp']}")
            if reply.get("notify_text"):
                print(f"notify: {reply['notify_text']}")
        else:
            for sid, s in reply.get("sessions", {}).items():
                print(f"{sid}  {s['project']:<20} {s['mode']:<9} {s['age']}s ago")
    elif cmd in ("greeting", "note"):
        pass  # dazzler-only vocabulary; accept silently for fan-out scripts
    else:
        print(f"unknown command: {cmd}", file=sys.stderr)
        return 1
    return 0


if __name__ == "__main__":
    sys.exit(main(sys.argv[1:]))
